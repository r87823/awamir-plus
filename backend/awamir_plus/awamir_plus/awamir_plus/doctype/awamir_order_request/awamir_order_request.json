  "fields": [
    {"fieldname": "order_number", "label": "Order Number", "fieldtype": "Data", "read_only": 1, "unique": 1},
    {"fieldname": "customer_section", "label": "Customer", "fieldtype": "Section Break"},
    {"fieldname": "customer", "label": "Customer", "fieldtype": "Link", "options": "Customer"},
    {"fieldname": "customer_name", "label": "Customer Name", "fieldtype": "Data", "reqd": 1},
    {"fieldname": "customer_phone", "label": "Customer Phone", "fieldtype": "Data", "reqd": 1},
    {"fieldname": "customer_type", "label": "Customer Type", "fieldtype": "Select", "options": "Individual\nCompany", "default": "Individual"},
    {"fieldname": "company_name", "label": "Company Name", "fieldtype": "Data"},
    {"fieldname": "tax_id", "label": "Tax ID", "fieldtype": "Data"},
    {"fieldname": "company_address", "label": "Company Address", "fieldtype": "Small Text"},
    {"fieldname": "company_email", "label": "Company Email", "fieldtype": "Data"},
    {"fieldname": "contact_person", "label": "Contact Person", "fieldtype": "Data"},
    {"fieldname": "branch_section", "label": "Branch and Delivery", "fieldtype": "Section Break"},
    {"fieldname": "created_branch", "label": "Created Branch", "fieldtype": "Link", "options": "Branch", "reqd": 1},
    {"fieldname": "pickup_branch", "label": "Pickup Branch", "fieldtype": "Link", "options": "Branch"},
    {"fieldname": "delivery_type", "label": "Delivery Type", "fieldtype": "Select", "options": "Pickup\nDelivery", "default": "Pickup", "reqd": 1},
    {"fieldname": "delivery_address", "label": "Delivery Address", "fieldtype": "Small Text"},
    {"fieldname": "delivery_location_url", "label": "Delivery Location URL", "fieldtype": "Data"},
    {"fieldname": "latitude", "label": "Latitude", "fieldtype": "Float"},
    {"fieldname": "longitude", "label": "Longitude", "fieldtype": "Float"},
    {"fieldname": "delivery_notes", "label": "Delivery Notes", "fieldtype": "Small Text"},
    {"fieldname": "delivery_fee", "label": "Delivery Fee", "fieldtype": "Currency", "default": 0},
    {"fieldname": "schedule_section", "label": "Schedule", "fieldtype": "Section Break"},
    {"fieldname": "required_date", "label": "Required Date", "fieldtype": "Date", "reqd": 1},
    {"fieldname": "required_time", "label": "Required Time", "fieldtype": "Time", "reqd": 1},
    {"fieldname": "order_notes", "label": "Order Notes", "fieldtype": "Small Text"},
    {"fieldname": "customer_notes", "label": "Customer Notes", "fieldtype": "Small Text"},
    {"fieldname": "status", "label": "Status", "fieldtype": "Select", "options": "Draft\nPending Supervisor Approval\nReturned For Edit\nRejected\nSent To Distribution\nSent To Production\nIn Production\nProduction Completed\nReady For Pickup\nReady For Delivery\nAssigned To Driver\nDriver Picked Up\nOut For Delivery\nDelivered\nDelivery Failed\nCancelled", "default": "Draft", "reqd": 1},
    {"fieldname": "items", "label": "Items", "fieldtype": "Table", "options": "Awamir Order Request Item", "reqd": 1},
    {"fieldname": "attachments", "label": "Attachments", "fieldtype": "Table", "options": "Awamir Order Attachment"},
    {"fieldname": "amounts_section", "label": "Amounts", "fieldtype": "Section Break"},
    {"fieldname": "total_amount", "label": "Total Amount", "fieldtype": "Currency", "default": 0},
    {"fieldname": "deposit_amount", "label": "Deposit Amount", "fieldtype": "Currency", "default": 0},
    {"fieldname": "remaining_amount", "label": "Remaining Amount", "fieldtype": "Currency", "default": 0, "read_only": 1},
    {"fieldname": "erp_section", "label": "ERPNext Sync", "fieldtype": "Section Break"},
    {"fieldname": "erpnext_sales_order", "label": "ERPNext Sales Order", "fieldtype": "Link", "options": "Sales Order", "read_only": 1},
    {"fieldname": "erpnext_work_order", "label": "ERPNext Work Order", "fieldtype": "Link", "options": "Work Order", "read_only": 1},
    {"fieldname": "erpnext_sales_invoice", "label": "ERPNext Sales Invoice", "fieldtype": "Link", "options": "Sales Invoice", "read_only": 1},
    {"fieldname": "erp_sync_status", "label": "ERP Sync Status", "fieldtype": "Select", "options": "Not Synced\nPending\nSynced\nFailed\nPartially Synced", "default": "Not Synced"},
    {"fieldname": "erp_sync_error", "label": "ERP Sync Error", "fieldtype": "Small Text", "read_only": 1},
    {"fieldname": "erp_synced_at", "label": "ERP Synced At", "fieldtype": "Datetime", "read_only": 1},
    {"fieldname": "workflow_section", "label": "Workflow", "fieldtype": "Section Break"},
    {"fieldname": "production_department", "label": "Production Department", "fieldtype": "Link", "options": "Awamir Production Department"},
    {"fieldname": "assigned_driver", "label": "Assigned Driver", "fieldtype": "Link", "options": "User"},
    {"fieldname": "created_by_user", "label": "Created By User", "fieldtype": "Link", "options": "User", "read_only": 1},
    {"fieldname": "approved_by", "label": "Approved By", "fieldtype": "Link", "options": "User", "read_only": 1},
    {"fieldname": "approved_at", "label": "Approved At", "fieldtype": "Datetime", "read_only": 1}
  ],
  "permissions": [
    {"role": "Awamir Branch Employee", "read": 1, "write": 1, "create": 1, "permlevel": 0},
    {"role": "Awamir Branch Supervisor", "read": 1, "write": 1, "permlevel": 0},
    {"role": "Awamir Distribution Manager", "read": 1, "write": 1, "permlevel": 0},
    {"role": "Awamir Production User", "read": 1, "write": 1, "permlevel": 0},
    {"role": "Awamir Driver", "read": 1, "permlevel": 0},
    {"role": "Awamir Accountant", "read": 1, "permlevel": 0},
    {"role": "Awamir System Admin", "read": 1, "write": 1, "create": 1, "delete": 1, "permlevel": 0}
  ]
}
