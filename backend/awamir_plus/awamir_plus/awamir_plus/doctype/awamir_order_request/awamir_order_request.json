    {"fieldname": "erpnext_sales_invoice", "label": "ERPNext Sales Invoice", "fieldtype": "Link", "options": "Sales Invoice", "read_only": 1},
    {"fieldname": "erp_sync_status", "label": "ERP Sync Status", "fieldtype": "Select", "options": "Not Synced\nPending\nSynced\nFailed\nPartially Synced", "default": "Not Synced"},
