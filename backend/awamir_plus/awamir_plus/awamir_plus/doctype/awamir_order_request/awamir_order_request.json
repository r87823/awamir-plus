{
  "doctype": "DocType",
  "name": "Awamir Order Request",
  "module": "Awamir Plus",
  "custom": 0,
  "allow_rename": 0,
  "track_changes": 1,
  "autoname": "field:order_number",
  "title_field": "order_number",
  "sort_field": "modified",
  "sort_order": "DESC",
  "field_order": [
    "order_number",
    "customer_section",
    "customer",
    "customer_name",
    "customer_phone",
    "customer_type",
    "company_name",
    "tax_id",
    "company_address",
    "company_email",
    "contact_person",
    "branch_section",
    "created_branch",
    "pickup_branch",
    "delivery_type",
    "delivery_address",
    "delivery_location_url",
    "latitude",
    "longitude",
    "delivery_notes",
    "delivery_fee",
    "schedule_section",
    "required_date",
    "required_time",
    "order_notes",
    "customer_notes",
    "status",
    "items",
    "attachments",
    "amounts_section",
    "total_amount",
    "deposit_amount",
    "remaining_amount",
    "erp_section",
    "erpnext_sales_order",
    "erpnext_work_order",
    "erpnext_sales_invoice",
    "erp_sync_status",
    "erp_sync_error",
    "erp_synced_at",
    "workflow_section",
    "production_department",
    "assigned_driver",
    "created_by_user",
    "approved_by",
