    {"fieldname": "is_cancelled", "label": "Is Cancelled", "fieldtype": "Check", "default": 0, "read_only": 1},
    {"fieldname": "cancelled_at", "label": "Cancelled At", "fieldtype": "Datetime", "read_only": 1},
    {"fieldname": "cancelled_by", "label": "Cancelled By", "fieldtype": "Link", "options": "User", "read_only": 1},
    {"fieldname": "cancellation_reason", "label": "Cancellation Reason", "fieldtype": "Small Text", "read_only": 1}
